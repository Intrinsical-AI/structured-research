{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "<task_name> record schema",
  "type": "object",
  "properties": {
    "entity": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "posted_at": {
      "type": "string",
      "format": "date"
    },
    "apply_url": {
      "type": "string",
      "format": "uri"
    },
    "geo": {
      "type": "object",
      "properties": {
        "region": {
          "type": "string"
        },
        "city": {
          "type": "string"
        }
      },
      "required": ["region"]
    },
    "recency": {
      "type": "object",
      "properties": {
        "activity_age_days": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "field": {
            "type": "string"
          },
          "quote": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "locator": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": ["type", "value"]
          }
        },
        "required": ["id", "field", "quote", "url", "retrieved_at", "locator"]
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "value": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null",
              "array",
              "object"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["field", "value", "evidence_ids"]
      }
    },
    "inferences": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "value": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null",
              "array",
              "object"
            ]
          },
          "reason": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["field", "value", "reason", "confidence", "evidence_ids"]
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "incomplete": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  }
  ,
  "required": [
    "entity",
    "title",
    "posted_at",
    "apply_url",
    "evidence",
    "facts",
    "inferences"
  ],
  "additionalProperties": true
}
