{
  "openapi": "3.1.0",
  "info": {
    "title": "structured-search API",
    "description": "Task-scoped HTTP API for structured, auditable search workflows.",
    "version": "0.3.0"
  },
  "paths": {
    "/v1/tasks": {
      "get": {
        "summary": "List registered tasks",
        "operationId": "get_tasks_v1_tasks_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/TaskSummary"
                  },
                  "type": "array",
                  "title": "Response Get Tasks V1 Tasks Get"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{task_id}/profiles": {
      "get": {
        "summary": "List available profiles for one task",
        "operationId": "get_profiles_v1_tasks__task_id__profiles_get",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProfileSummary"
                  },
                  "title": "Response Get Profiles V1 Tasks  Task Id  Profiles Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{task_id}/profiles/{profile_id}/bundle": {
      "get": {
        "summary": "Load a task/profile bundle",
        "operationId": "get_bundle_v1_tasks__task_id__profiles__profile_id__bundle_get",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          },
          {
            "name": "profile_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Profile Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileBundle"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Validate and save a task/profile bundle",
        "operationId": "put_bundle_v1_tasks__task_id__profiles__profile_id__bundle_put",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          },
          {
            "name": "profile_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Profile Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileBundle"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BundleWriteResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{task_id}/prompt/generate": {
      "post": {
        "summary": "Compose an extraction prompt for a task/profile and step",
        "operationId": "post_generate_prompt_v1_tasks__task_id__prompt_generate_post",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptGenerateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptGenerateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{task_id}/jsonl/validate": {
      "post": {
        "summary": "Parse JSONL tolerantly and validate records against task schema",
        "operationId": "post_jsonl_validate_v1_tasks__task_id__jsonl_validate_post",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonlValidateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonlValidateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{task_id}/run/validate": {
      "post": {
        "summary": "Dry-run validation for run prerequisites without scoring",
        "operationId": "post_task_run_validate_v1_tasks__task_id__run_validate_post",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunScoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunValidateSummary"
                }
              }
            }
          },
          "404": {
            "description": "Task/profile not found"
          },
          "422": {
            "description": "Validation/config error"
          }
        }
      }
    },
    "/v1/tasks/{task_id}/run": {
      "post": {
        "summary": "Score pre-validated records using task profile runtime config",
        "operationId": "post_task_run_v1_tasks__task_id__run_post",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunScoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunScoreResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task/profile not found"
          },
          "422": {
            "description": "Validation/config error"
          },
          "500": {
            "description": "Run failed"
          }
        }
      }
    },
    "/v1/tasks/{task_id}/actions/gen-cv": {
      "post": {
        "summary": "Generate a CV markdown and structured JSON",
        "operationId": "post_action_gen_cv_v1_tasks__task_id__actions_gen_cv_post",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenCVRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenCVResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task/profile not found"
          },
          "422": {
            "description": "Validation error in request payload"
          },
          "503": {
            "description": "CV provider unavailable"
          }
        }
      }
    }
  },
