[importlinter]
root_package = structured_search
include_external_packages = False

[importlinter:domain_purity]
name = Domain purity
type = forbidden
source_modules =
    structured_search.domain
forbidden_modules =
    structured_search.ports
    structured_search.infra
    structured_search.api
    structured_search.application

[importlinter:ports_isolation]
name = Ports isolation
type = forbidden
source_modules =
    structured_search.ports
forbidden_modules =
    structured_search.infra
    structured_search.api
    structured_search.application

[importlinter:infra_isolation]
name = Infra isolation
type = forbidden
source_modules =
    structured_search.infra
forbidden_modules =
    structured_search.api

[importlinter:application_rules]
name = Application cannot depend on API
type = forbidden
source_modules =
    structured_search.application
forbidden_modules =
    structured_search.api

[importlinter:application_infra_isolation]
name = Application layer cannot import from infra
type = forbidden
source_modules =
    structured_search.application
forbidden_modules =
    structured_search.infra

[importlinter:api_controller_thin]
name = API app stays thin and framework-facing
type = forbidden
source_modules =
    structured_search.api.app
forbidden_modules =
    structured_search.infra
    structured_search.domain
    structured_search.ports
allow_indirect_imports = True
