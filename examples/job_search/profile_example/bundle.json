{
    "profile_id": "profile_example",
    "constraints": {
        "domain": "job_search",
        "sources": {
            "primary": [
                "linkedin",
                "glassdoor"
            ],
            "secondary": [
                "remoteok"
            ],
            "fallback": []
        },
        "must": [
            {
                "field": "modality",
                "op": "in",
                "value": [
                    "remote",
                    "hybrid"
                ],
                "reason": "I only want remote or hybrid jobs."
            }
        ],
        "prefer": [
            {
                "field": "stack",
                "op": "contains_any",
                "value": [
                    "python",
                    "typescript",
                    "react"
                ],
                "weight": 2.5
            }
        ],
        "avoid": [
            {
                "field": "seniority.level",
                "op": "=",
                "value": "junior",
                "severity": 1.0,
                "reason": "Avoid junior roles if possible."
            }
        ],
        "limits": {},
        "relaxation": {
            "order": [],
            "steps": {},
            "emit_constraints_diff": false
        }
    },
    "task": {
        "gates": {
            "must_pass_constraints_must": true,
            "hard_filters_mode": "any",
            "hard_filters": [],
            "reject_anomalies": [
                "prompt_injection_suspected"
            ],
            "required_evidence_fields": []
        },
        "soft_scoring": {
            "formula_version": "v2_soft_after_gates",
            "prefer_weight_default": 1.0,
            "avoid_penalty_default": 1.0,
            "signal_boost": {
                "salary_disclosed": 1.5,
                "evidence_present": 0.5
            },
            "penalties": {
                "missing_salary": 1.0,
                "incomplete": 2.0
            }
        }
    },
    "task_config": {
        "agent_name": "JS_AGENT",
        "version": "1.0",
        "language_priority": [
            "en",
            "es"
        ],
        "max_results": 20,
        "target_results": [
            5,
            15
        ]
    },
    "user_profile": {
        "timezone": "Europe/Madrid",
        "mobility": "remote",
        "risk_tolerance": "medium",
        "currency_default": "EUR",
        "language_preference": [
            "en",
            "es"
        ]
    }
}